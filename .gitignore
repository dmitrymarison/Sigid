.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# macOS
.DS_Store

# Environment files
.env
.env.local
.env.*.local

